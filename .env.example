# FinAlly — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# Required: OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=

# Optional: Massive (Polygon.io) API key for real market data.
# If not set (or empty), the built-in market simulator is used.
# NOTE: The free-tier snapshot endpoint returns 403. The simulator
#       is the recommended and fully-supported data source.
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (testing/CI)
LLM_MOCK=false
